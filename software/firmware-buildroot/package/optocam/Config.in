config BR2_PACKAGE_OPTOCAM
	bool "optocam"
	depends on BR2_INSTALL_LIBSTDCPP
	depends on BR2_TOOLCHAIN_HAS_THREADS
	depends on BR2_PACKAGE_LIBCAMERA
	select BR2_PACKAGE_JPEG
	select BR2_PACKAGE_FREETYPE
	help
	  Optocam Zero native firmware app: libcamera capture, ST7789
	  preview, HUD, still/GIF capture, and gallery. Installs the main
	  optocam_app plus the minimal optocam_preview fallback launched
	  by the S03display init script.

	  https://github.com/dorukkumkumoglu/optocamzero

comment "optocam needs libcamera and a toolchain w/ C++, threads"
	depends on !BR2_INSTALL_LIBSTDCPP || !BR2_TOOLCHAIN_HAS_THREADS || \
		!BR2_PACKAGE_LIBCAMERA
